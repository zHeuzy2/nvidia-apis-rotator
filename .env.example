# ==========================================
# Configuração do NVIDIA API Rotator
# ==========================================

# Porta do servidor (SquareCloud usa 80)
PORT=80

# Ambiente
NODE_ENV=production

# ==========================================
# Performance & Scaling
# ==========================================

# Modo Cluster - Spawns multiple workers (1 per CPU core)
# ATIVAR para alta performance em servidores multi-core
# DESATIVE para ambientes como SquareCloud que gerenciam workers via config
CLUSTER_MODE=true

# Nível de Log (DEBUG, INFO, WARN, ERROR)
# INFO é recomendado para produção
LOG_LEVEL=INFO

# ==========================================
# APIs NVIDIA NIM
# Adicione quantas quiser seguindo o padrão:
# NVIDIA_API_KEY_1, NVIDIA_API_KEY_2, etc.
# ==========================================

# API 1
NVIDIA_API_KEY_1=
NVIDIA_API_NAME_1=NVIDIA API 1
NVIDIA_API_URL_1=https://integrate.api.nvidia.com/v1

# API 2
NVIDIA_API_KEY_2=
NVIDIA_API_NAME_2=NVIDIA API 2
NVIDIA_API_URL_2=https://integrate.api.nvidia.com/v1

# API 3 (adicione mais conforme necessário)
NVIDIA_API_KEY_3=
NVIDIA_API_NAME_3=NVIDIA API 3
NVIDIA_API_URL_3=https://integrate.api.nvidia.com/v1

# ==========================================
# Configuração de Modelos
# ==========================================

# Modelo padrão usado quando não especificado na requisição
# Opções: moonshotai/kimi-k2.6 (recomendado), deepseek-ai/deepseek-v4-pro,
#          z-ai/glm-5.1, minimaxai/minimax-m2.7
DEFAULT_MODEL=moonshotai/kimi-k2.6

# ==========================================
# Segurança
# ==========================================

# Chave de API para usar o proxy (opcional)
# Se definida, clientes precisam enviar esta chave
# Deixe vazio para permitir acesso sem autenticação
PROXY_API_KEY=


# ==========================================
# CORS
# ==========================================

# Origem permitida (* para todas)
CORS_ORIGIN=*
