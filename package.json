{
  "name": "nvidia-api-rotator",
  "version": "2.0.0",
  "description": "Sistema de rotação e balanceamento de APIs NVIDIA NIM com métricas detalhadas",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "benchmark": "node scripts/benchmark.js",
    "benchmark:full": "node scripts/benchmark.js --streaming --requests=20",
    "benchmark:local": "node scripts/benchmark.js http://localhost:3000"
  },
  "keywords": [
    "nvidia",
    "nim",
    "api",
    "rotator",
    "load-balancer",
    "proxy"
  ],
