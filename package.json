  "dependencies": {
    "cacheable-lookup": "^7.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "undici": "^8.3.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
